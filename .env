# ── ParkSense AI – Environment Configuration ──────────────────────────────────
# Copy this to .env and fill in your values

# ── Flask (RPi) ───────────────────────────────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=change-me-in-production-use-a-long-random-string
HOST=192.168.137.170
PORT=5000

# ── Database ──────────────────────────────────────────────────────────────────
# Default: SQLite in ./database/parking.db
# DATABASE_URL=postgresql://user:pass@localhost/parking

# ── ZeroMQ (PC ↔ RPi) ────────────────────────────────────────────────────────
PC_IP=192.168.137.1
PC_PORT=5555
ZMQ_TIMEOUT_MS=10000

# ── Simulation ────────────────────────────────────────────────────────────────
SIMULATION_MODE=false

# ── Camera ────────────────────────────────────────────────────────────────────
CAMERA_INDEX=0
CAMERA_MODE=pc

# ── GPIO (Raspberry Pi only) ──────────────────────────────────────────────────
ULTRASONIC_TRIGGER=23
ULTRASONIC_ECHO=24
DISTANCE_THRESHOLD=2.0
SERVO_PIN=18
SERVO_OPEN_ANGLE=90
SERVO_CLOSE_ANGLE=0
SERVO_OPEN_SECS=3.0
BUTTON_PIN=25
BUTTON_DEBOUNCE_MS=300

# ── AI Model (PC only) ────────────────────────────────────────────────────────
MODEL_PATH=./pc/model/model.pt
YOLO_CONF=0.50
YOLO_IOU=0.45
OCR_DEVICE=cpu

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO